{
  "name": "kn-graph-workbench",
  "private": true,
  "version": "0.1.0",
  "description": "KN Graph Workbench - Desktop app for knowledge graph exploration and AI-powered research",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:electron": "VITE_DEV_SERVER_URL=http://localhost:3000 NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "deploy": "npm run build && node -e \"const fs=require('fs');const p=require('path');const src=p.resolve('dist');const dst=p.resolve('..','frontend_legacy','workbench_spa');if(fs.existsSync(dst)){fs.rmSync(dst,{recursive:true})}fs.cpSync(src,dst,{recursive:true});console.log('Deployed to',dst)\"",
    "lint": "tsc --noEmit",
    "electron": "electron .",
    "electron:dev": "npm run build && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.kn.graph.workbench",
    "productName": "KN Graph Workbench",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/main.cjs",
      "electron/preload.cjs",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.21",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
