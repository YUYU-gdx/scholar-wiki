{
    "name": "scholar-wiki",
    "private": true,
    "version": "0.1.10",
    "description": "Scholar Wiki - Desktop app for academic knowledge graph exploration and AI-powered research",
    "main": "electron/main.cjs",
    "type": "module",
    "scripts": {
        "dev": "vite --port=3000 --host=0.0.0.0",
        "dev:electron": "set VITE_DEV_SERVER_URL=http://localhost:3000&& set NODE_ENV=development&& electron .",
        "start": "npm run build && electron .",
        "build": "vite build",
        "preview": "vite preview",
        "clean": "rm -rf dist",
        "deploy": "npm run build && node -e \"const fs=require('fs');const p=require('path');const src=p.resolve('dist');const dst=p.resolve('..','outputs','workbench_spa');if(fs.existsSync(dst)){fs.rmSync(dst,{recursive:true})}fs.cpSync(src,dst,{recursive:true});console.log('Deployed to',dst)\"",
        "lint": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:electron:reader": "node e2e/reader.electron.playwright.mjs",
        "electron": "electron .",
        "electron:dev": "npm run dev:electron",
        "pack": "electron-builder --dir",
        "dist": "uv run pyinstaller --distpath .\\dist --workpath .\\build ..\\kn_graph.spec && copy /Y .\\dist\\kn_graph.exe ..\\dist_exe\\kn_graph.exe && electron-builder"
    },
    "build": {
        "appId": "com.scholar.wiki",
        "productName": "Scholar Wiki",
        "icon": "build/icon.png",
        "directories": {
            "output": "../dist_exe"
        },
        "files": [
            "electron/main.cjs",
            "electron/preload.cjs",
            "dist/**/*",
            "!dist/kn_graph.exe"
        ],
        "extraResources": [
            {
                "from": "../dist_exe/kn_graph.exe",
                "to": "."
            }
        ],
        "win": {
            "icon": "build/icon.png",
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "mac": {
            "target": [
                "dmg"
            ]
        },
        "linux": {
            "target": [
                "AppImage"
            ]
        }
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.18.6",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/language": "^6.12.3",
        "@codemirror/language-data": "^6.5.2",
        "@codemirror/search": "^6.7.0",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.41.1",
        "@playwright/test": "^1.59.1",
        "@tailwindcss/vite": "^4.1.14",
        "@vitejs/plugin-react": "^5.0.4",
        "@vscode/markdown-it-katex": "^1.1.2",
        "dompurify": "^3.4.2",
        "highlight.js": "^11.11.1",
        "idb": "^8.0.3",
        "katex": "^0.16.45",
        "lightningcss-win32-x64-msvc": "^1.32.0",
        "lucide-react": "^0.546.0",
        "markdown-it": "^14.1.1",
        "markdown-it-deflist": "^3.0.0",
        "markdown-it-footnote": "^4.0.0",
        "markdown-it-katex": "^2.0.3",
        "markdown-it-mark": "^4.0.0",
        "markdown-it-task-lists": "^2.1.1",
        "mermaid": "^11.15.0",
        "pdfjs-dist": "^5.4.296",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-force-graph-3d": "^1.29.1",
        "react-markdown": "^9.1.0",
        "react-pdf": "^10.4.1",
        "rehype-katex": "^7.0.1",
        "remark-gfm": "^4.0.1",
        "remark-math": "^6.0.0",
        "three": "^0.184.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^22.14.0",
        "@types/react": "^19.2.14",
        "autoprefixer": "^10.4.21",
        "electron": "^31.7.7",
        "electron-builder": "^24.13.3",
        "fake-indexeddb": "^6.2.5",
        "jsdom": "^29.1.1",
        "playwright": "^1.59.1",
        "tailwindcss": "^4.1.14",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "vite": "^6.2.0",
        "vitest": "^4.1.5"
    }
}
